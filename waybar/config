{
  "modules-left": ["sway/workspaces"],
  "modules-center": ["sway/window"],
  "modules-right": ["cpu", "pulseaudio", "clock", "battery"],

  "sway/workspaces": {
      "all-outputs": true,
      "disable-scroll": false,
      "format": "{icon}",
      "format-icons": {
          "default": "○",
          "focused": "●",
          "urgent": "!"
      }
  },

  "cpu": {
      "interval": 2,
      "format": "CPU {usage}%",
      "max-length": 10
  },

  "pulseaudio": {
      "format": "{icon} {volume}%",
      "format-muted": "🔇",
      "format-icons": {
          "default": ["", "", ""]
      },
      "on-click": "alacritty -e 'pulsemixer'",
      "scroll-step": 5
  },

  "clock": {
      "interval": 60,
      "format": "{:%H:%M}" // Shows only Hours and Minutes
  },

  "battery": {
      "states": {
          "warning": 30,
          "critical": 15
      },
      "format": "{icon} {capacity}%",
      "format-charging": "⚡ {capacity}%",
      "format-icons": ["", "", "", "", ""]
  }
}
